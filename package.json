{
  "name": "@tamma/doc-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "deploy": "react-router build && wrangler deploy",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply tamma-docs",
    "db:migrate:local": "wrangler d1 migrations apply tamma-docs --local",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-database.ts",
    "db:seed:remote": "SEED_REMOTE=true tsx scripts/seed-database.ts",
    "db:reset": "pnpm db:migrate:local && pnpm db:seed",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:unit": "vitest run --grep -i '(integration|e2e)'",
    "test:integration": "vitest run --grep -i 'integration'",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:coverage:ui": "vitest --ui --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:report": "playwright show-report",
    "test:e2e:update-snapshots": "playwright test --update-snapshots",
    "test:e2e:ci": "playwright test --project=chromium playwright/tests/homepage.spec.ts playwright/tests/search.spec.ts playwright/tests/documents.spec.ts",
    "playwright:install": "playwright install --with-deps",
    "lighthouse": "lhci autorun",
    "lighthouse:install": "npm install -g @lhci/cli@0.14.x"
  },
  "dependencies": {
    "@react-router/cloudflare": "^7.14.2",
    "@react-router/dev": "^7.14.2",
    "@react-router/node": "^7.14.2",
    "dayjs": "^1.11.20",
    "diff": "^8.0.3",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.39",
    "lucide-react": "^0.553.0",
    "nanoid": "^5.1.9",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.14.2",
    "rehype-highlight": "^7.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "resend": "^6.12.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/workers-types": "^4.20260426.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["workerd", "esbuild", "sharp"]
  }
}
